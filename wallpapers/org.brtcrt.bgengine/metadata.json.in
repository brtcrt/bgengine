{
    "KPackageStructure": "Plasma/Wallpaper",
    "KPlugin": {
        "Authors": [
            {
                "Name": "brtcrt"
            }
        ],
        "Category": "",
        "Description": "Shader and media background engine",
        "Icon": "preferences-desktop-wallpaper",
        "Id": "@BGENGINE_ID@",
        "License": "GPL-3.0-or-later",
        "Name": "@BGENGINE_DISPLAY_NAME@",
        "Website": "https://kde.org/plasma-desktop"
    },
    "Keywords": "shader;video;wallpaper;background;",
    "MimeType": "image/avif;image/gif;image/heif;image/jpeg;image/png;image/svg+xml;image/svg+xml-compressed;image/bmp;image/webp;image/tiff;video/mp4;video/webm;",
    "X-KDE-ParentApp": "org.kde.plasmashell",
    "X-Plasma-DropMimeTypes": [
        "image/avif",
        "image/gif",
        "image/heif",
        "image/jpeg",
        "image/png",
        "image/svg+xml",
        "image/svg+xml-compressed",
        "image/bmp",
        "image/webp",
        "image/tiff",
        "video/mp4",
        "video/webm"
    ]
}
